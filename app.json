{
  "expo": {
    "name": "Twin.me",
    "slug": "twin-me",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "twinme",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.twin.app"
    },
    "android": {
      "package": "me.twin.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0D1A"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "OOTD 사진을 선택하기 위해 갤러리 접근 권한이 필요해요."
        }
      ],
      [
        "react-native-iap",
        {
          "paymentProvider": "both"
        }
      ]
    ]
  }
}
